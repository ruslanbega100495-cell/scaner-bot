// Marketplace Infographic Generation System + Freelance Scanner - Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER - Пользователи системы
// ============================================

model User {
  id               String  @id @default(uuid())
  email            String  @unique
  passwordHash     String
  telegramId       BigInt? @unique
  telegramUsername String?

  // Тариф
  plan          PlanType  @default(FREE)
  planExpiresAt DateTime?

  // Лимиты
  jobsThisMonth Int @default(0)
  jobLimit      Int @default(5)

  // Интеграции
  googleDriveToken String? @db.Text
  yandexDiskToken  String? @db.Text

  // Настройки
  defaultMarketplace Marketplace @default(WILDBERRIES)
  timezone           String      @default("UTC")

  // Статистика
  totalJobs   Int @default(0)
  totalImages Int @default(0)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastActiveAt DateTime @default(now())

  jobs         Job[]
  integrations Integration[]

  @@index([email])
  @@index([telegramId])
  @@index([plan])
}

enum PlanType {
  FREE
  PRO
  BUSINESS
  ENTERPRISE
}

enum Marketplace {
  WILDBERRIES
  YANDEX_MARKET
  OZON
  KAZANEXPRESS
}

// ============================================
// JOB - Задания на обработку
// ============================================

model Job {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Статус
  status   JobStatus @default(PENDING)
  progress Int       @default(0)

  // Файлы
  originalFileName String
  originalFilePath String
  totalRows        Int
  processedRows    Int    @default(0)
  failedRows       Int    @default(0)

  // Результаты
  csvFilePath    String?
  csvDownloadUrl String?
  imagesCount    Int     @default(0)

  // Ошибки
  errorMessage String? @db.Text

  // Временные метки
  startedAt   DateTime?
  completedAt DateTime?
  expiresAt   DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items Item[]

  @@index([userId, status])
  @@index([status, createdAt])
  @@index([expiresAt])
}

enum JobStatus {
  PENDING
  UPLOADING
  PROCESSING
  GENERATING
  UPLOADING_IMAGES
  GENERATING_CSV
  COMPLETED
  FAILED
  EXPIRED
}

// ============================================
// ITEM - Товары из Excel
// ============================================

model Item {
  id    String @id @default(uuid())
  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  // Данные из Excel
  rowNumber Int
  article   String
  brand     String?
  name      String?

  // Характеристики (JSON)
  characteristics Json

  // Изображения
  sourceImageUrl   String
  sourceImageLocal String?

  // Статус обработки
  status       ItemStatus @default(PENDING)
  errorMessage String?

  // Сгенерированные изображения
  images Image[]

  // CSV данные
  csvData Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([jobId, article])
  @@index([jobId, status])
  @@index([article])
}

enum ItemStatus {
  PENDING
  DOWNLOADING_IMAGE
  PROCESSING
  UPLOADING_IMAGES
  COMPLETED
  FAILED
}

// ============================================
// IMAGE - Сгенерированные изображения
// ============================================

model Image {
  id     String @id @default(uuid())
  itemId String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  // Тип изображения
  type ImageType

  // Файл
  localPath       String
  storageProvider StorageProvider
  storageId       String
  publicUrl       String?         @db.Text

  // Размеры
  width    Int
  height   Int
  fileSize Int

  // Статус загрузки
  uploadStatus UploadStatus @default(PENDING)
  uploadError  String?
  retryCount   Int          @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([itemId, type])
  @@index([storageProvider, storageId])
}

enum ImageType {
  MAIN
  FEATURES
  BENEFITS
  DETAILS
}

enum StorageProvider {
  LOCAL
  GOOGLE_DRIVE
  YANDEX_DISK
}

enum UploadStatus {
  PENDING
  UPLOADING
  COMPLETED
  FAILED
}

// ============================================
// INTEGRATION - Интеграции с сервисами
// ============================================

model Integration {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider     IntegrationProvider
  accessToken  String              @db.Text
  refreshToken String?             @db.Text
  expiresAt    DateTime?

  // Метаданные
  metadata Json?

  isActive   Boolean   @default(true)
  lastUsedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, provider])
}

enum IntegrationProvider {
  GOOGLE_DRIVE
  YANDEX_DISK
  GOOGLE_SHEETS
  TELEGRAM
}

// ============================================
// SCANNER - Модели для сканера фриланс-заказов
// ============================================

model ScannerSource {
  id            Int        @id @default(autoincrement())
  name          String     @unique
  type          SourceType
  url           String
  isActive      Boolean    @default(true)
  scanInterval  Int        @default(300)
  rateLimit     Int        @default(60)
  lastScannedAt DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  scannerJobs ScannerJob[]

  @@index([name])
  @@index([type])
}

enum SourceType {
  WEBSITE
  TELEGRAM
  API
  RSS
}

model ScannerJob {
  id         Int           @id @default(autoincrement())
  externalId String?
  sourceId   Int
  source     ScannerSource @relation(fields: [sourceId], references: [id])

  // Данные заказа
  url         String  @unique
  title       String
  description String? @db.Text
  priceMin    Int?
  priceMax    Int?

  // AI анализ
  aiScore    Int     @default(0)
  aiReason   String? @db.Text
  isSuitable Boolean @default(false)

  // Статус
  status ScannerJobStatus @default(NEW)

  // Временные метки
  scrapedAt   DateTime  @default(now())
  processedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notifications ScannerNotification[]

  @@index([sourceId])
  @@index([status])
  @@index([isSuitable])
  @@index([scrapedAt])
}

enum ScannerJobStatus {
  NEW
  PROCESSING
  READY
  REJECTED
  SENT
  FAILED
}

model ScannerNotification {
  id    Int        @id @default(autoincrement())
  jobId Int
  job   ScannerJob @relation(fields: [jobId], references: [id])

  userId     String
  telegramId BigInt
  message    String @db.Text

  status       NotificationStatus @default(PENDING)
  sentAt       DateTime?
  errorMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobId])
  @@index([telegramId])
  @@index([status])
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

// ============================================
// USER SETTINGS - Настройки фильтров пользователя
// ============================================

model UserSettings {
  id         Int      @id @default(autoincrement())
  telegramId BigInt   @unique
  keywords   String[]
  minPrice   Int?
  maxPrice   Int?
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([telegramId])
  @@map("UserSettings")
}
