# Твой основной URL (с пулером или без, для локальной разработки лучше без -pooler)
DATABASE_URL="postgresql://authenticator:пароль@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# Для тени (shadow) нужно использовать ТОЧНО ТАКОЙ ЖЕ хост, но можно с другим именем БД, 
# если есть права создавать БД. Но на бесплатном Neon прав нет.
# Поэтому мы схитрим: для GitHub Actions мы укажем фейковый URL, а для локалки оставим пустым или таким же.
# НО! Для бесплатного Neon есть нюанс: shadowDatabaseUrl часто вызывает ошибки при migrate dev.
# Поэтому для локальной разработки лучше закомментировать shadowDatabaseUrl в schema.prisma, 
# а для GitHub оставить.

# ПОПРАВКА ДЛЯ NEON FREE TIER:
# Так как мы не можем создавать базы данных для shadow, мы будем использовать один URL.
# В schema.prisma для локалки закомментируй shadowDatabaseUrl, если будут ошибки.
# А для GitHub мы передадим его через переменную окружения.
